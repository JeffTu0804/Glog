# =============================================================================
# glog 後端環境變數範本
# 複製此檔為 .env 並填入 Supabase 後台的連線字串
# =============================================================================

# 伺服器埠號（可選，預設 3000）
PORT=3000

# 前端 CORS 來源（Phase 5）
CORS_ORIGIN="http://localhost:5173"

# Prisma 連線字串（Transaction Pooler — 供應用程式日常查詢使用）
# Supabase 後台路徑：Project Settings → Database → Connection string → URI
# 選擇 "Transaction" 模式，port 為 6543，結尾需加上 ?pgbouncer=true
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma 直連字串（Direct Connection — 供 migrate 遷移使用）
# Supabase 後台路徑：Project Settings → Database → Connection string → URI
# 選擇 "Session" 模式，port 為 5432
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Supabase Auth 設定（Project Settings → API）
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
# LINE 登入需要（Project Settings → API → service_role，勿暴露到前端）
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# LINE Login（LINE Developers Console → LINE Login channel）
LINE_CHANNEL_ID=""
LINE_CHANNEL_SECRET=""
LINE_REDIRECT_URI="http://localhost:3000/api/v1/auth/line/callback"
FRONTEND_URL="http://localhost:5173"
BACKEND_PUBLIC_URL="http://localhost:3000"

# LINE Messaging API（交班推播用，Messaging API → Channel access token）
# 可與 LINE Login 同一 Channel，或另建 Messaging API Channel
LINE_MESSAGING_ACCESS_TOKEN=""

# Manager 申請通知 Email（可用 Gmail SMTP + App Password）
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS="" # Gmail 請填 16 碼 App Password，不是一般登入密碼
SMTP_FROM="glog <your-gmail@gmail.com>"
MANAGER_APPROVAL_NOTIFY_TO="jeff.tu804@gmail.com"
MANAGER_APPROVAL_LINK_SECRET=""

# OpenAI（選填，用於 AI 交班摘要；未設定則使用規則摘要）
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
SEED_SUPABASE_USER_ID=""
SEED_ENGINEER_SUPABASE_USER_ID=""

# 平台營運後台管理員（Supabase Auth UUID，與飯店員工分開）
SEED_PLATFORM_ADMIN_SUPABASE_USER_ID=""
