// =============================================================================
// glog — 飯店後勤 ERP Prisma Schema
// 多租戶架構：所有核心業務表均透過 tenantId 關聯 Tenant，確保租戶資料嚴格隔離
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

/// 員工角色：決定後台操作權限與可見功能範圍
enum UserRole {
  ADMIN         // 系統管理員：全權管理租戶設定與人員
  FRONT_DESK    // 前台人員：可建立報修工單、查看資產狀態
  HOUSEKEEPING  // 房務人員：可回報客房問題、觸發清潔相關工單
  ENGINEER      // 工程師：接收派單、執行維修並回報完工
  FOOD_BEVERAGE // 餐飲部：處理餐廳預約等服務請求
}

/// 飯店部門（跨部門服務請求路由用）
enum Department {
  FRONT_DESK
  FOOD_BEVERAGE
  HOUSEKEEPING
  ENGINEERING
  MANAGEMENT
}

/// 員工即時狀態：供自動派單演算法判斷工程師是否可接單
enum UserStatus {
  IDLE  // 閒置：可接受新工單指派
  BUSY  // 忙碌：已有進行中工單，暫不派單
}

/// 資產類型：區分客房與各類硬體設施
enum AssetType {
  ROOM       // 客房
  EQUIPMENT  // 設備（空調、電梯、熱水器等）
  FACILITY   // 公共設施（健身房、游泳池等）
}

/// 資產運作狀態：追蹤設備/客房的可用性
enum AssetStatus {
  OPERATIONAL   // 正常運作
  MAINTENANCE   // 維護中（有進行中工單）
  OUT_OF_ORDER  // 故障停用
}

/// 工單生命週期狀態：落實「觸發 → 派單 → 執行 → 結案」閉環
enum TicketStatus {
  OPEN               // 新建：等待派單
  ASSIGNED           // 已指派：工程師已接單
  IN_PROGRESS        // 進行中：工程師現場作業
  PENDING_FRONT_DESK // 待前台協助（換房、協調客人等）
  COMPLETED          // 已完工：等待財務結案（扣庫存、寫入 CostLog）
  CLOSED             // 已結案：閉環完成
  CANCELLED          // 已取消
}

/// 工程師回報類型
enum TicketResolutionType {
  COMPLETED          // 已處理完成
  NEEDS_FRONT_DESK   // 無法處理，需前台協助
}

/// 工單附件類型
enum TicketAttachmentKind {
  COMPLETION   // 完工照片
  ESCALATION   // 升級/無法處理照片
}

/// 工單優先級：影響派單排序與 SLA 時限
enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

/// SaaS 訂閱方案
enum SubscriptionPlan {
  TRIAL       // 試用
  STARTER     // 入門
  PRO         // 專業
  ENTERPRISE  // 企業
}

/// 租戶訂閱狀態
enum SubscriptionStatus {
  ACTIVE     // 正常使用中
  TRIAL      // 試用中
  PAST_DUE   // 逾期未付款
  SUSPENDED  // 已暫停服務
  CANCELLED  // 已取消
}

/// 班別類型（台北時間）
enum ShiftType {
  MORNING    // 早班 07:00–15:00
  AFTERNOON  // 中班 15:00–23:00
  NIGHT      // 晚班 23:00–07:00
}

/// 交班日誌狀態
enum ShiftLogbookStatus {
  OPEN       // 進行中，可新增備註
  PUBLISHED  // 已交班，AI 摘要已產生
}

/// 跨部門服務請求類型
enum ServiceRequestType {
  RESTAURANT_RESERVATION // 餐廳預約
  GENERAL                // 一般請求
}

/// 服務請求狀態
enum ServiceRequestStatus {
  PENDING   // 待部門處理
  CONFIRMED // 已確認
  REJECTED  // 已拒絕
  CANCELLED // 已取消
  COMPLETED // 已完成
}

/// 提醒狀態
enum ReminderStatus {
  SCHEDULED  // 排程中
  TRIGGERED  // 已觸發（待處理）
  DISMISSED  // 已處理
  CANCELLED  // 已取消
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

/// Auth 擴充資料（public.profiles）— 對應 auth.users，控制前台/Manager 入口
model AuthProfile {
  id                  String   @id @db.Uuid /// 對應 auth.users.id
  email               String?
  name                String?
  role                String   @default("user") /// user / manager
  managerAccessStatus String   @default("none") @map("manager_access_status") /// none / pending / approved / rejected
  managerRequestedAt  DateTime? @map("manager_requested_at") @db.Timestamptz(6)
  managerReviewedAt   DateTime? @map("manager_reviewed_at") @db.Timestamptz(6)
  managerReviewedBy   String?  @map("manager_reviewed_by") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("profiles")
}

/// 平台管理員（PlatformAdmin）— 保留既有資料；實際 Manager 入口改由 profiles.role 控制
model PlatformAdmin {
  id             String   @id @default(cuid())
  supabaseUserId String   @unique /// 對應 Supabase Auth UUID
  email          String   @unique
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Models (Tenant-scoped)
// ---------------------------------------------------------------------------

/// 租戶（Tenant）— 飯店或飯店集團的主表，為多租戶隔離的根節點
model Tenant {
  id                 String             @id @default(cuid())
  name               String             /// 飯店或集團顯示名稱
  slug               String             @unique /// URL 友善識別碼，全系統唯一
  contactEmail       String?            /// 飯店聯絡信箱
  plan               SubscriptionPlan   @default(TRIAL) /// 訂閱方案
  subscriptionStatus SubscriptionStatus @default(TRIAL) /// 訂閱狀態
  subscriptionEndsAt DateTime?          /// 訂閱到期日
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // --- 一對多關聯：刪除租戶時級聯清除所有子資料 ---
  users              User[]
  assets             Asset[]
  maintenanceTickets MaintenanceTicket[]
  inventoryItems     Inventory[]
  costLogs           CostLog[]
  shiftLogbooks      ShiftLogbook[]
  shiftLogEntries    ShiftLogEntry[]
  serviceRequests    ServiceRequest[]
  reminders          Reminder[]
  ticketAttachments  TicketAttachment[]
  hotel              Hotel?
}

/// 員工（User）— 綁定 Supabase Auth，隸屬單一租戶
model User {
  id             String     @id @default(cuid())
  tenantId       String     /// 所屬租戶 ID（多租戶隔離鍵）
  supabaseUserId String     @unique /// 對應 Supabase Auth 的 UUID，全系統唯一
  email          String     /// 員工電子郵件
  name           String     /// 員工顯示名稱
  role           UserRole   /// 角色權限
  status         UserStatus @default(IDLE) /// 即時狀態（閒置/忙碌），供派單演算法使用
  skills         String[]   /// 專業標籤（如 "plumbing", "electrical", "hvac"），供智能派單匹配
  lineUserId     String?    /// LINE 使用者 ID（OAuth sub），供交班推播
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // --- 多對一：員工隸屬單一租戶 ---
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // --- 一對多：員工作為工單觸發人或被指派的工程師 ---
  triggeredTickets MaintenanceTicket[] @relation("TicketTriggeredBy")
  assignedTickets  MaintenanceTicket[] @relation("TicketAssignedTo")
  logbooksCreated  ShiftLogbook[]      @relation("LogbookCreatedBy")
  logbooksPublished ShiftLogbook[]     @relation("LogbookPublishedBy")
  shiftLogEntries  ShiftLogEntry[]
  serviceRequestsCreated ServiceRequest[] @relation("ServiceRequestCreatedBy")
  serviceRequestsHandled ServiceRequest[] @relation("ServiceRequestHandledBy")
  ticketAttachments      TicketAttachment[] @relation("TicketAttachmentUploadedBy")
  guestRequestsHandled GuestRequest[]     @relation("GuestRequestHandledBy")

  @@unique([tenantId, email]) /// 同一租戶內 email 不可重複
  @@index([tenantId])
  @@index([tenantId, role, status]) /// 加速派單查詢：依角色與狀態篩選可用工程師
  @@index([tenantId, lineUserId])
}

/// 資產（Asset）— 客房或硬體設備，追蹤運作狀態
model Asset {
  id          String      @id @default(cuid())
  tenantId    String      /// 所屬租戶 ID（多租戶隔離鍵）
  name        String      /// 資產名稱（如「101 號房」、「B 棟空調主機」）
  code        String      /// 資產編號（如房號、設備序號），租戶內唯一
  type        AssetType   /// 資產類型
  status      AssetStatus @default(OPERATIONAL) /// 當前運作狀態
  location    String?     /// 物理位置（樓層、棟別等）
  description String?     /// 備註說明
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // --- 多對一：資產隸屬單一租戶 ---
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // --- 一對多：此資產關聯的所有維修工單 ---
  maintenanceTickets MaintenanceTicket[]

  // --- 一對一：住客 QR 客房（可選） ---
  guestRoom Room?

  @@unique([tenantId, code]) /// 同一租戶內資產編號不可重複
  @@index([tenantId])
  @@index([tenantId, status]) /// 加速查詢特定狀態的資產（如所有故障房）
}

/// 維修工單（MaintenanceTicket）— 核心業務實體，串連觸發、派單、執行、結案閉環
model MaintenanceTicket {
  id            String         @id @default(cuid())
  tenantId      String         /// 所屬租戶 ID（多租戶隔離鍵）
  assetId       String         /// 關聯資產
  triggeredById String         /// 觸發人（建立工單的員工）
  assignedToId  String?        /// 指派工程師（派單後填入，待派單時為 null）
  title         String         /// 工單標題
  description   String?        /// 問題描述
  status        TicketStatus   @default(OPEN) /// 工單當前狀態
  priority      TicketPriority @default(MEDIUM) /// 優先級
  triggeredAt   DateTime       @default(now()) /// 觸發時間
  assignedAt    DateTime?      /// 派單時間
  completedAt      DateTime?             /// 完工時間
  closedAt         DateTime?             /// 結案時間（含庫存扣除與成本結算）
  resolutionNote   String?               /// 工程師回報說明
  resolutionType   TicketResolutionType? /// 回報類型
  resolutionAt     DateTime?             /// 回報時間
  frontDeskNote    String?               /// 前台協調備註
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  // --- 多對一：工單隸屬單一租戶 ---
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // --- 多對一：工單關聯的資產 ---
  asset Asset @relation(fields: [assetId], references: [id])

  // --- 多對一：觸發此工單的員工 ---
  triggeredBy User @relation("TicketTriggeredBy", fields: [triggeredById], references: [id])

  // --- 多對一：被指派執行的工程師（可為空） ---
  assignedTo User? @relation("TicketAssignedTo", fields: [assignedToId], references: [id])

  // --- 一對多：工單結案時產生的成本紀錄 ---
  costLogs CostLog[]

  // --- 一對多：完工/升級照片 ---
  attachments TicketAttachment[]

  // --- 一對多：跨部門提醒 ---
  reminders Reminder[]

  @@index([tenantId])
  @@index([tenantId, status]) /// 加速依狀態篩選工單列表
  @@index([assignedToId]) /// 加速查詢工程師的工單
  @@index([assetId]) /// 加速查詢特定資產的維修歷史
}

/// 耗材庫存（Inventory）— 後勤備品管理，工單結案時透過 Transaction 扣除
model Inventory {
  id           String   @id @default(cuid())
  tenantId     String   /// 所屬租戶 ID（多租戶隔離鍵）
  name         String   /// 耗材名稱
  sku          String?  /// 料號（Stock Keeping Unit），租戶內唯一
  category     String?  /// 分類（如「衛浴」、「電器零件」）
  quantity     Int      @default(0) /// 目前庫存量
  unit         String   @default("個") /// 計量單位
  unitCost     Decimal  @db.Decimal(10, 2) /// 單位成本（新台幣或指定幣別）
  reorderLevel Int      @default(0) /// 安全庫存警戒線，低於此值觸發補貨提醒
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // --- 多對一：庫存項目隸屬單一租戶 ---
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, sku]) /// 同一租戶內料號不可重複
  @@index([tenantId])
}

/// 成本紀錄（CostLog）— 工單結案時寫入，追蹤維護財務損益
model CostLog {
  id          String   @id @default(cuid())
  tenantId    String   /// 所屬租戶 ID（多租戶隔離鍵）
  ticketId    String?  /// 關聯工單（結案時產生，獨立成本紀錄可為 null）
  description String   /// 成本項目說明（如「更換水龍頭零件 × 2」）
  amount      Decimal  @db.Decimal(10, 2) /// 金額
  category    String?  /// 成本分類（如「耗材」、「人工」、「外包」）
  recordedAt  DateTime @default(now()) /// 成本發生時間
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // --- 多對一：成本紀錄隸屬單一租戶 ---
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // --- 多對一：關聯的工單（可選） ---
  ticket MaintenanceTicket? @relation(fields: [ticketId], references: [id])

  @@index([tenantId])
  @@index([ticketId]) /// 加速查詢特定工單的所有成本
}

/// 交班日誌（Shift Logbook）— 每班次的 AI 摘要與交接紀錄
model ShiftLogbook {
  id            String             @id @default(cuid())
  tenantId      String
  department    Department         @default(FRONT_DESK) /// 所屬部門，各部門獨立交班日誌
  shiftType     ShiftType
  shiftDate     DateTime           @db.Date /// 班別起始日（台北時間）
  shiftStart    DateTime           /// 班別開始（UTC）
  shiftEnd      DateTime           /// 班別結束（UTC）
  status        ShiftLogbookStatus @default(OPEN)
  aiSummary     String?            @db.Text /// AI 產生的交班摘要
  highlights    String[]           /// 重點條列
  openItems     String[]           /// 待接班追蹤事項
  snapshotJson  Json?              /// 原始事件快照（供除錯）
  createdById   String
  publishedById String?
  publishedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy   User            @relation("LogbookCreatedBy", fields: [createdById], references: [id])
  publishedBy User?           @relation("LogbookPublishedBy", fields: [publishedById], references: [id])
  entries     ShiftLogEntry[]

  @@unique([tenantId, department, shiftType, shiftDate])
  @@index([tenantId, department, status])
  @@index([tenantId, department, publishedAt])
}

/// 班別內手動備註
model ShiftLogEntry {
  id        String   @id @default(cuid())
  tenantId  String
  logbookId String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logbook ShiftLogbook @relation(fields: [logbookId], references: [id], onDelete: Cascade)
  author  User         @relation(fields: [authorId], references: [id])

  @@index([tenantId])
  @@index([logbookId])
}

/// 跨部門服務請求（如餐廳預約）
model ServiceRequest {
  id               String               @id @default(cuid())
  tenantId         String
  type             ServiceRequestType   @default(RESTAURANT_RESERVATION)
  status           ServiceRequestStatus @default(PENDING)
  title            String
  description      String?
  guestRoom        String               /// 房號（如 305）
  guestName        String               /// 客人姓名
  targetDepartment Department           /// 接收部門
  sourceDepartment Department           @default(FRONT_DESK)
  createdById      String
  handledById      String?
  scheduledAt      DateTime             /// 預約／服務時間
  reminderAt       DateTime?            /// 提醒前台通知客人的時間
  responseNote     String?              /// 處理部門回覆
  confirmedAt      DateTime?
  rejectedAt       DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User       @relation("ServiceRequestCreatedBy", fields: [createdById], references: [id])
  handledBy User?      @relation("ServiceRequestHandledBy", fields: [handledById], references: [id])
  reminders Reminder[]

  @@index([tenantId])
  @@index([tenantId, targetDepartment, status])
  @@index([tenantId, createdById])
  @@index([tenantId, scheduledAt])
}

/// 工單現場照片（完工確認或升級佐證）
model TicketAttachment {
  id           String               @id @default(cuid())
  tenantId     String
  ticketId     String
  uploadedById String
  url          String               /// 公開存取路徑
  mimeType     String               @default("image/jpeg")
  kind         TicketAttachmentKind
  createdAt    DateTime             @default(now())

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticket     MaintenanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy User              @relation("TicketAttachmentUploadedBy", fields: [uploadedById], references: [id])

  @@index([tenantId])
  @@index([ticketId])
}

/// 服務提醒（如預約前 30 分鐘通知客人、工程完工通知）
model Reminder {
  id                  String         @id @default(cuid())
  tenantId            String
  serviceRequestId    String?
  maintenanceTicketId String?
  guestRequestId      String?        @db.Uuid
  title               String
  message             String
  remindAt            DateTime
  status              ReminderStatus @default(SCHEDULED)
  notifyDepartment    Department     @default(FRONT_DESK)
  triggeredAt         DateTime?
  dismissedAt         DateTime?
  createdAt           DateTime       @default(now())

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceRequest    ServiceRequest?    @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  maintenanceTicket MaintenanceTicket? @relation(fields: [maintenanceTicketId], references: [id], onDelete: Cascade)
  guestRequest      GuestRequest?      @relation(fields: [guestRequestId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, remindAt])
  @@index([serviceRequestId])
  @@index([maintenanceTicketId])
  @@index([guestRequestId])
}

// ---------------------------------------------------------------------------
// 住客掃碼請求（免登入，與 hotels / rooms / guest_requests 表對應）
// ---------------------------------------------------------------------------

/// 飯店租戶（住客 QR 模組，與 Tenant 一對一）
model Hotel {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @unique
  name              String
  lineOfficialToken String?  @map("line_official_token")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rooms         Room[]
  guestRequests GuestRequest[]

  @@map("hotels")
}

/// 客房（含 QR 識別金鑰）
model Room {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotelId    String   @map("hotel_id") @db.Uuid
  assetId    String?  @unique @map("asset_id")
  roomNumber String   @map("room_number")
  qrToken    String   @unique @map("qr_token")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  hotel         Hotel          @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  asset         Asset?         @relation(fields: [assetId], references: [id], onDelete: SetNull)
  guestRequests GuestRequest[]

  @@unique([hotelId, roomNumber])
  @@index([hotelId])
  @@map("rooms")
}

/// 住客服務請求
model GuestRequest {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotelId          String     @map("hotel_id") @db.Uuid
  roomId           String     @map("room_id") @db.Uuid
  requestType      String     @map("request_type")
  targetDepartment Department @map("target_department")
  status           String     @default("pending")
  notes            String?    @db.Text
  handledById      String?    @map("handled_by_id")
  completedAt      DateTime?  @map("completed_at") @db.Timestamptz(6)
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  hotel     Hotel      @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  room      Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  handledBy User?      @relation("GuestRequestHandledBy", fields: [handledById], references: [id])
  reminders Reminder[]

  @@index([hotelId])
  @@index([roomId])
  @@index([hotelId, status])
  @@index([hotelId, targetDepartment, status])
  @@index([createdAt])
  @@map("guest_requests")
}
