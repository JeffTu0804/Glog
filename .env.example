# =============================================================================
# glog 後端環境變數範本
# 複製此檔為 .env 並填入 Supabase 後台的連線字串
# =============================================================================

# 伺服器埠號（可選，預設 3000）
PORT=3000

# 前端 CORS 來源（Phase 5）
CORS_ORIGIN="http://localhost:5173"

# Prisma 連線字串（Transaction Pooler — 供應用程式日常查詢使用）
# Supabase 後台路徑：Project Settings → Database → Connection string → URI
# 選擇 "Transaction" 模式，port 為 6543，結尾需加上 ?pgbouncer=true
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma 直連字串（Direct Connection — 供 migrate 遷移使用）
# Supabase 後台路徑：Project Settings → Database → Connection string → URI
# 選擇 "Session" 模式，port 為 5432
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Supabase Auth 設定（Project Settings → API）
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

# Seed 腳本用：Supabase Auth 建立使用者後，填入其 UUID
SEED_SUPABASE_USER_ID=""
SEED_ENGINEER_SUPABASE_USER_ID=""

# 平台營運後台管理員（Supabase Auth UUID，與飯店員工分開）
SEED_PLATFORM_ADMIN_SUPABASE_USER_ID=""
